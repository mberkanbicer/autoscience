FROM python:3.11-slim

RUN groupadd -r sandbox -g 1000 && useradd -r -u 1000 -g sandbox -m sandbox

RUN pip install --no-cache-dir \
    numpy==1.26.4 \
    pandas==2.2.2 \
    scipy==1.13.1 \
    scikit-learn==1.5.1 \
    matplotlib==3.9.0 \
    statsmodels==0.14.2

WORKDIR /app
USER sandbox

CMD ["python", "experiment.py"]